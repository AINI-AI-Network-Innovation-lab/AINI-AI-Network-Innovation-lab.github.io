---
import { getCollection } from "astro:content";
import ProjectCard from "../components/ProjectCard.astro";
import ResearchCard from "../components/ResearchCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { byOrder } from "../lib/content";

const research = byOrder(await getCollection("research"));
const projects = byOrder(await getCollection("projects"));
---
<BaseLayout title="Research" description="Research areas and featured projects from AINI Lab.">
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Research</p>
      <h1>Research in AI systems and networks.</h1>
      <p class="section-copy">From edge AI to networked infrastructure.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid three-up">
        {research.map((entry) => (
          <ResearchCard title={entry.data.title} summary={entry.data.summary} tags={entry.data.tags} />
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="card-grid three-up">
        {projects.map((entry) => (
          <ProjectCard
            title={entry.data.title}
            summary={entry.data.summary}
            tags={entry.data.tags}
            links={entry.data.links}
          />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
