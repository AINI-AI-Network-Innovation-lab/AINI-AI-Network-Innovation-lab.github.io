---
import ResourceGrid from "../components/ResourceGrid.astro";
import resources from "../data/resources.json";
import BaseLayout from "../layouts/BaseLayout.astro";
import type { ResourceItem } from "../types";

const typedResources = [...(resources as ResourceItem[])].sort((a, b) => a.order - b.order);
---
<BaseLayout title="Resources" description="Starter resources, code links, and research entry points from AINI Lab.">
  <section class="page-hero">
    <div class="container narrow">
      <p class="eyebrow">Resources</p>
      <h1>Lab resources.</h1>
      <p class="section-copy">Public resources in one place.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <ResourceGrid resources={typedResources} />
    </div>
  </section>
</BaseLayout>
