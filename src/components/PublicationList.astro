---
import type { Publication } from "../types";
import { groupPublicationsByYear } from "../lib/content";

interface Props {
  publications: Publication[];
  grouped?: boolean;
  compact?: boolean;
}

const { publications, grouped = false, compact = false } = Astro.props;

const groups = grouped ? groupPublicationsByYear(publications) : null;
const years = groups ? Object.keys(groups).sort((a, b) => Number(b) - Number(a)) : [];
---
{grouped && groups ? (
  <div class="publication-groups">
    {years.map((year) => (
      <section class="publication-year">
        <h3>{year}</h3>
        <ul class="publication-list">
          {groups[year].map((publication) => (
            <li class="publication-item">
              <div class="publication-meta-row">
                <p class="publication-venue">{publication.venue}</p>
                <div class="link-row">
                  {publication.paperUrl && <a href={publication.paperUrl}>Scholar</a>}
                  {publication.codeUrl && <a href={publication.codeUrl}>Code</a>}
                </div>
              </div>
              <strong class="publication-title">
                {publication.paperUrl ? <a href={publication.paperUrl}>{publication.title}</a> : publication.title}
              </strong>
              <p class="publication-authors">{publication.authors.join(", ")}</p>
              {publication.topicTags && (
                <ul class="tag-list">
                  {publication.topicTags.map((tag) => <li>{tag}</li>)}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
) : (
  <ul class="publication-list">
    {publications.map((publication) => (
      <li class="publication-item">
        <div class="publication-meta-row">
          <p class="publication-venue">{publication.venue} · {publication.year}</p>
          {publication.paperUrl && (
            <div class="link-row">
              <a href={publication.paperUrl}>Scholar</a>
            </div>
          )}
        </div>
        <strong class="publication-title">
          {publication.paperUrl ? <a href={publication.paperUrl}>{publication.title}</a> : publication.title}
        </strong>
        {!compact && <p class="publication-authors">{publication.authors.join(", ")}</p>}
        {publication.topicTags && (
          <ul class="tag-list">
            {publication.topicTags.map((tag) => <li>{tag}</li>)}
          </ul>
        )}
      </li>
    ))}
  </ul>
)}
