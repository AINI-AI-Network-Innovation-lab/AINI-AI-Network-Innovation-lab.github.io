---
import type { CollectionEntry } from "astro:content";

interface Props {
  entries: CollectionEntry<"news">[];
  compact?: boolean;
}

const { entries, compact = false } = Astro.props;
---
<div class="news-list">
  {entries.map((entry) => (
    <article class="content-card news-card">
      <p class="eyebrow">{entry.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}</p>
      <h3>{entry.data.title}</h3>
      {!compact && <p>{entry.data.summary}</p>}
      {entry.data.links && (
        <div class="link-row">
          {entry.data.links.map((link) => <a href={link.href}>{link.label}</a>)}
        </div>
      )}
    </article>
  ))}
</div>
